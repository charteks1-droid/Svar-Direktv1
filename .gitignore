# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# Environment variables — never commit these
.env
.env.*
!.env.example
!.env.*.example

# Credentials and secrets
*.key
*.pem
*.p12
*.p8
*.cer
*.pfx
service-account.json
google-services.json
GoogleService-Info.plist
credentials.json
secrets.json

# Android keystores
*.keystore
*.jks
android/app/release.keystore
android/app/debug.keystore
android/app/google-services.json

# iOS signing
ios/Pods/
*.mobileprovision
*.xcarchive
ExportOptions.plist
ios/GoogleService-Info.plist

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pino-*
/libpeerconnection.log
testem.log

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/
