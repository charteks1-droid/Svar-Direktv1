{
  "expo": {
    "name": "Svar Direkt",
    "slug": "svar-direkt-new",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "svar-direkt",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.svardirekt.app"
    },
    "android": {
      "package": "com.svardirekt.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0a7ea4"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "./plugins/withJava17"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiBaseUrl": "https://c11fb1aa-c8a5-494a-82d5-6e40e01b85cc-00-151780krlaqfm.kirk.replit.dev/api",
      "eas": {
        "projectId": "0e221c32-280f-44c7-a998-e7aa0a722e0c"
      }
    }
  }
}
