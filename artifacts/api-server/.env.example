JWT_SECRET=change-this-to-a-strong-random-secret-min-32-chars

# Database
DATABASE_URL=postgres://user:password@localhost:5432/svar_direkt

# AI (auto-provisioned by Replit AI Integrations — do not set manually in Replit)
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=500

# Stripe (for future payment phase)
STRIPE_SECRET_KEY=
